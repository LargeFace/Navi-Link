<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="38dp"
    android:layout_marginStart="3dp"
    android:background="@drawable/bg_traffic_light_capsule"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="2dp"
    android:paddingEnd="6dp">

    <FrameLayout
        android:layout_width="32dp"
        android:layout_height="32dp">

        <ImageView
            android:id="@+id/iv_light_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_traffic_light_yellow" />

        <ImageView
            android:id="@+id/iv_light_arrow"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_gravity="center"
            android:padding="3dp"
            android:scaleType="centerInside"
            android:src="@mipmap/light_straight" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_light_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="3dp"
        android:layout_marginEnd="2dp"
        android:includeFontPadding="false"
        android:text="等"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

</LinearLayout>
